# Optional: Anthropic API key for AI-generated commentary summaries.
# Copy to .env and fill in your key. The dashboard works without it.
ANTHROPIC_API_KEY=

# Optional: override the default commentary model (default: claude-haiku-4-5)
# ANTHROPIC_MODEL=claude-haiku-4-5

# Optional: API port (default: 3847)
# PORT=3847

# Optional: telemetry endpoint override for hooks and simulators
# DASHBOARD_URL=http://localhost:3847/api/v1/telemetry

# Optional: project ID for simulators (default: "default" or Electron active project)
# DASHBOARD_PROJECT=
